# Postgres (Neon, Supabase, or local). Required by Prisma.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (NextAuth v5). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me"

# ---------- Optionnel : envoi d'emails via Resend ----------
# Sans RESEND_API_KEY, l'app log les emails dans la console serveur
# au lieu de les envoyer (dev fallback). Aucune erreur côté utilisateur.
#
# Pour activer l'envoi réel :
#   1. Compte gratuit sur https://resend.com (3000 emails/mois gratuits)
#   2. Générer une API key dans le dashboard Resend
#   3. Pour tester sans domaine vérifié : utiliser onboarding@resend.dev
#      (les emails ne partent qu'à l'adresse du compte Resend).
#   4. Pour la prod : vérifier votre domaine et utiliser hello@votredomaine.com
RESEND_API_KEY=
RESEND_FROM="onboarding@resend.dev"

# URL absolue utilisée pour construire les liens dans les emails
# (par défaut : NEXTAUTH_URL ou http://localhost:3000)
APP_URL="http://localhost:3000"
